# ======================================================================
# 🚀 Inazuma Ecosystem 全局聚合编译脚本 (Mixed Build System)
# ======================================================================

# 定义核心子模块的物理目录
KV_DIR      = inazuma-kv
GATEWAY_DIR = inazuma-ai-gateway
CHAT_DIR    = inazuma-chat-server
TOKEN_DIR   = tokenizer
LOG_DIR     = logs

# 伪目标声明
.PHONY: all clean kv gateway chat run stop init_env help

# ======================================================================
# 🎯 默认构建目标：一键编译全宇宙
# ======================================================================
all: init_env kv gateway chat
	@echo "======================================================================"
	@echo " ✨ [SUCCESS] ⚡ Inazuma Ecosystem 全矩阵 C++ 核心编译圆满完成！"
	@echo " 🐍 [INFO] Tokenizer 为纯 Python 微服务，将在容器构建时自动拉取依赖。"
	@echo " 📂 运行日志与 PID 将统一输出至: $(ROOT_DIR)/$(LOG_DIR)/"
	@echo " 🚀 下一步操作建议:"
	@echo "    - 物理点火: 执行 'make run' (将直接调用 start.sh 拉起集群)"
	@echo "    - 容器点火: 执行 'sudo docker-compose up -d --build'"
	@echo "======================================================================"

# ======================================================================
# 📢 启动横幅与环境初始化
# ======================================================================
init_env:
	@echo "======================================================================"
	@echo " 🛠️  [INIT] 正在唤醒 Inazuma 核心构建矩阵..."
	@echo " ⚙️  构建架构: Make (KV底座) + CMake (网关与业务) + Python (分词)"
	@echo "======================================================================"
	@echo " 📁 [Env] 正在检查并初始化全局日志与进程目录..."
	@mkdir -p $(LOG_DIR)
	@echo " ✅ [Env] $(LOG_DIR)/ 目录已就绪。"

# ======================================================================
# 🔨 分布式模块编译指令 (混合调度)
# ======================================================================

# 1. 传统 Make 编译 (KV底座)
kv:
	@echo ""
	@echo "----------------------------------------------------------------------"
	@echo " 📦 [1/3] 正在构建: InazumaKV (极速缓存底座) -> [Make 模式]"
	@echo " 🔌 底层特性: AF_XDP 旁路网络加速 | Epoll 多路复用"
	@echo "----------------------------------------------------------------------"
	@$(MAKE) -C $(KV_DIR)
	@echo " ✅ [OK] InazumaKV 编译通过！"

# 2. CMake 编译 (AI Gateway)
gateway:
	@echo ""
	@echo "----------------------------------------------------------------------"
	@echo " 🛰️ [2/3] 正在构建: Inazuma AI Gateway (大模型路由网关) -> [CMake 模式]"
	@echo " 🔌 底层特性: 零拷贝语义缓存 | io_uring 高并发 | SSE 平滑推流"
	@echo "----------------------------------------------------------------------"
	@mkdir -p $(GATEWAY_DIR)/build
	@cd $(GATEWAY_DIR)/build && cmake .. && $(MAKE)
	@echo " ✅ [OK] AI Gateway 编译通过！"

# 3. CMake 编译 (Chat Server)
chat:
	@echo ""
	@echo "----------------------------------------------------------------------"
	@echo " 💰 [3/3] 正在构建: Inazuma Chat Server (业务逻辑层) -> [CMake 模式]"
	@echo " 🔌 底层特性: JWT 安全认证 | 计费引擎 | MySQL 异步落盘"
	@echo "----------------------------------------------------------------------"
	@mkdir -p $(CHAT_DIR)/build
	@cd $(CHAT_DIR)/build && cmake .. && $(MAKE)
	@echo " ✅ [OK] Chat Server 编译通过！"

# ======================================================================
# 🧹 全局物理超度 (清理遗留产物)
# ======================================================================
clean:
	@echo "======================================================================"
	@echo " 🛑 [CLEAN UP] 正在执行全域物理超度，销毁所有历史构建产物..."
	@echo "======================================================================"
	@echo " 🧹 [1/3] 清理 InazumaKV (Make clean)..."
	@$(MAKE) -C $(KV_DIR) clean
	@echo " 🧹 [2/3] 清理 AI Gateway (删除 CMake build 目录)..."
	@rm -rf $(GATEWAY_DIR)/build $(GATEWAY_DIR)/bin
	@echo " 🧹 [3/3] 清理 Chat Server (删除 CMake build 目录)..."
	@rm -rf $(CHAT_DIR)/build $(CHAT_DIR)/bin
	@echo " 🧹 [4/4] 清理历史日志与 PID 记录..."
	@rm -f $(LOG_DIR)/*.log $(LOG_DIR)/*.pid
	@echo "======================================================================"
	@echo " 🗑️  [DONE] 所有构建缓存、日志、PID 文件已彻底灰飞烟灭！"
	@echo "======================================================================"

# ======================================================================
# 🚀 联动外围 Shell 脚本
# ======================================================================
run:
	@echo " 🚀 正在向 start.sh 移交最高控制权，准备物理点火..."
	@bash start.sh

stop:
	@echo " 🛑 正在向 stop.sh 移交最高控制权，启动安全熄火程序..."
	@bash stop.sh