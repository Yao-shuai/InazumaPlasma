# ==========================================
# 1. 构建产物 (Build Artifacts)
# ==========================================
# 忽略二进制输出目录和对象文件目录
/bin/
/obj/

# 忽略所有 C/C++ 编译生成的中间文件 (作为双重保险)
*.o
*.d
*.out
*.a
*.so
*.dylib

# ==========================================
# 2. 运行时日志与崩溃转储 (Logs & Core Dumps)
# ==========================================
*.log
core
core.*
vgcore.* # Valgrind 内存检测产生的临时文件
gmon.out       # gprof 性能分析生成的报告

# ==========================================
# 3. 操作系统与 IDE 缓存 (OS & IDE)
# ==========================================
# macOS
.DS_Store

# Windows
Thumbs.db

# VS Code / CLion / Vim
.vscode/
.idea/
*.swp
*.swo
*~